<!-- Add Feed Page — demonstrates input validation patterns in WinUI 3 -->
<Page
    x:Class="RssReader.Views.AddFeedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="using:RssReader.Common">

    <Page.Resources>
        <common:BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Add a feed" Style="{StaticResource TitleTextBlockStyle}" />

            <TextBlock Text="Enter the URL of an RSS or Atom feed to add it to your reading list."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <TextBox x:Name="FeedUrlBox" Header="Feed URL" 
                     PlaceholderText="https://example.com/feed"
                     TextChanged="FeedUrlBox_TextChanged" />

            <!-- Error message -->
            <InfoBar x:Name="ErrorInfoBar" IsOpen="False" Severity="Error" IsClosable="False" />

            <!-- Preview of detected feed -->
            <StackPanel x:Name="FeedPreview" Visibility="Collapsed" Spacing="8"
                        Padding="16" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                <TextBlock x:Name="FeedNameText" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock x:Name="FeedDescriptionText" 
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" MaxLines="3" />
            </StackPanel>

            <Button x:Name="AddButton" Style="{StaticResource AccentButtonStyle}"
                    Content="Add Feed" Click="AddButton_Click" IsEnabled="False" />
        </StackPanel>
    </ScrollViewer>
</Page>
