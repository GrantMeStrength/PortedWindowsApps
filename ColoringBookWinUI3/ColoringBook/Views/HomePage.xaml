<Page
    x:Class="ColoringBook.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ColoringBook.Models"
    NavigationCacheMode="Required"
    Loaded="OnLoaded">

    <!--
    MIGRATION NOTE: UWP Pivot → WinUI 3 TabView
    
    The UWP version used Pivot with PivotItems for "Library" and "My Colorings".
    Pivot is NOT available in WinUI 3. Options:
    1. TabView (used here) — closest equivalent, supports tabs with close/add
    2. NavigationView with top mode — for simpler navigation
    3. Custom Segmented control — CommunityToolkit.WinUI has Segmented control
    
    TabView provides:
    - Tab switching (Library / My Colorings)
    - Same visual hierarchy as Pivot
    - Familiar pattern for Windows 11 users
    -->

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with TabView-style segmented control -->
        <Grid Grid.Row="0" Padding="24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="4">
                <RadioButton x:Name="LibraryTab"
                             Content="Library"
                             IsChecked="True"
                             GroupName="HomeTabs"
                             Style="{StaticResource DefaultToggleButtonStyle}"
                             Checked="OnTabChanged" />
                <RadioButton x:Name="MyColoringsTab"
                             Content="My Colorings"
                             GroupName="HomeTabs"
                             Style="{StaticResource DefaultToggleButtonStyle}"
                             Checked="OnTabChanged" />
            </StackPanel>
        </Grid>

        <!-- Library images grid -->
        <GridView x:Name="LibraryGrid"
                  Grid.Row="1"
                  Padding="24,0,24,24"
                  ItemsSource="{x:Bind ViewModel.LibraryImages}"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="OnLibraryImageClicked">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:LibraryImage">
                    <Grid Width="250" Height="300"
                          CornerRadius="8"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Image Source="{x:Bind Thumbnail, Mode=OneWay}"
                               Stretch="Uniform"
                               Margin="8" />

                        <TextBlock Grid.Row="1"
                                   Text="{x:Bind Title}"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Padding="12,8"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- Saved colorings grid -->
        <GridView x:Name="ColoringsGrid"
                  Grid.Row="1"
                  Padding="24,0,24,24"
                  Visibility="Collapsed"
                  ItemsSource="{x:Bind ViewModel.SavedColorings}"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="OnColoringClicked">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Coloring">
                    <Grid Width="200" Height="250"
                          CornerRadius="8"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Image Source="{x:Bind Thumbnail, Mode=OneWay}"
                               Stretch="Uniform"
                               Margin="8" />

                        <StackPanel Grid.Row="1" Padding="12,8">
                            <TextBlock Text="{x:Bind Title}"
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- Loading indicator -->
        <ProgressRing Grid.Row="1"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="48" Height="48" />

        <!-- Empty state -->
        <TextBlock x:Name="EmptyStateText"
                   Grid.Row="1"
                   Text="No saved colorings yet. Pick an image from the Library to start!"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Opacity="0.6"
                   Visibility="Collapsed" />
    </Grid>
</Page>
