<Page
    x:Class="PhotoEditor.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PhotoEditor.Models"
    NavigationCacheMode="Enabled">

    <Page.Resources>
        <DataTemplate x:Key="PhotoItemTemplate" x:DataType="models:Photo">
            <Grid Width="300" Height="200" Margin="4"
                  CornerRadius="8"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Image x:Name="ItemImage"
                       Source="{x:Bind Thumbnail, Mode=OneWay}"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                    <ToolTipService.ToolTip>
                        <StackPanel>
                            <TextBlock Text="{x:Bind ImageTitle, Mode=OneWay}" 
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                                <Run Text="{x:Bind ImageFileType}" />
                                <Run Text=" • " />
                                <Run Text="{x:Bind ImageDimensions}" />
                            </TextBlock>
                        </StackPanel>
                    </ToolTipService.ToolTip>
                </Image>
            </Grid>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="PhotoGridPanel">
            <ItemsWrapGrid Orientation="Horizontal"
                           HorizontalAlignment="Center" />
        </ItemsPanelTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Padding="24,16" Grid.Row="0">
            <TextBlock Text="Collection"
                       Style="{StaticResource TitleTextBlockStyle}" />
        </Grid>

        <!-- Loading indicator -->
        <ProgressBar x:Name="LoadingBar"
                     Grid.Row="0"
                     VerticalAlignment="Bottom"
                     IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <!-- Main content -->
        <Grid Grid.Row="1">
            <!-- Parallax background -->
            <ParallaxView x:Name="ParallaxBackground"
                          VerticalShift="50"
                          Source="{x:Bind PhotoScroller}">
                <Image Source="ms-appx:///Assets/bg1.png"
                       Stretch="UniformToFill"
                       Opacity="0.3" />
            </ParallaxView>

            <!-- Photo grid -->
            <ScrollViewer x:Name="PhotoScroller">
                <GridView x:Name="ImageGridView"
                          Margin="16"
                          IsItemClickEnabled="True"
                          ItemClick="ImageGridView_ItemClick"
                          ItemsSource="{x:Bind ViewModel.Photos, Mode=OneWay}"
                          ItemsPanel="{StaticResource PhotoGridPanel}"
                          ItemTemplate="{StaticResource PhotoItemTemplate}"
                          Loaded="ImageGridView_Loaded">
                </GridView>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock x:Name="NoPicsText"
                       Text="No images found in your Pictures library. Add some photos and relaunch."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="48"
                       TextWrapping="WrapWholeWords"
                       Visibility="{x:Bind ViewModel.HasNoPhotos, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
